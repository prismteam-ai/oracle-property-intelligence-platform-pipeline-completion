{
  "name": "@oracle/model-gateway",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src",
    "test": "vitest run src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "4.0.137",
    "@aws-sdk/credential-providers": "3.1089.0",
    "@oracle/contracts": "workspace:*",
    "ai": "6.0.230",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@oracle/tsconfig": "workspace:*",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
