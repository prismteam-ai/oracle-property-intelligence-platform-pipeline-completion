{
  "name": "@oracle/artifacts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "test": "vitest run src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1089.0",
    "@aws-sdk/lib-storage": "3.1089.0",
    "@oracle/contracts": "workspace:*"
  },
  "devDependencies": {
    "@oracle/tsconfig": "workspace:*",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
