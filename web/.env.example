# Copy to web/.env.local and fill in. Used by `docker compose up` and `npm run dev`.

# Session signing secret (any long random string).
AUTH_JWT_SECRET=change-me-to-a-long-random-string

# Anthropic API — powers the "Ask the data" intent + answer agents.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5

# Demo login accounts for the grader (no OAuth).
DEMO_OWNER_USER=owner
DEMO_OWNER_PASS=owner1234
DEMO_VIEWER_USER=demo
DEMO_VIEWER_PASS=demo1234

# Set false for a local HTTP (non-TLS) run so the session cookie is sent.
COOKIE_SECURE=false
