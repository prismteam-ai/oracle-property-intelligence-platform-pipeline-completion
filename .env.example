# Documentation-only environment contract.
# Every value is an intentionally unusable placeholder. Never put a credential
# value in this file; inject secrets through the approved ingress path instead.

NODE_ENV=<development-or-production>

# Operator and deployment identity. Static AWS access keys are intentionally
# absent: local work selects an operator-managed profile and CI uses an approved
# identity mechanism only after its release gate is satisfied.
AWS_PROFILE=<operator-selected-profile-name>
AWS_REGION=<approved-aws-region>
AWS_ACCOUNT_ID=<target-aws-account-id>
AWS_ROLE_ARN=<approved-deployment-role-arn>

# Release-bound Oracle artifact inputs.
ORACLE_RELEASE_ID=<immutable-release-id>
ORACLE_PUBLIC_ARTIFACT_MANIFEST_URL=<immutable-https-manifest-url>
ORACLE_PUBLIC_ARTIFACT_MANIFEST_SHA256=<lowercase-sha256-of-manifest>
ORACLE_PUBLIC_MIRROR_BASE_URL=<approved-https-mirror-base-url>
ORACLE_IPNS_NAME=<approved-public-ipns-name>

# Model profile metadata. The application uses the Vercel AI SDK Bedrock route;
# direct provider API keys are not part of this contract.
BEDROCK_MODEL_ID=<approved-bedrock-model-profile-id>

# Filebase-compatible S3 publication values. Credential values must be injected
# at runtime from an approved secret store or an explicit ignored local file.
FILEBASE_S3_ENDPOINT=<approved-filebase-s3-endpoint>
FILEBASE_BUCKET=<approved-filebase-bucket-name>
FILEBASE_ACCESS_KEY_ID=<inject-at-runtime-from-approved-secret-store>
FILEBASE_SECRET_ACCESS_KEY=<inject-at-runtime-from-approved-secret-store>

# Conditional Team Kit integrations. These names document the boundary only;
# their ORA-008 applicability gates must be resolved before either is enabled.
LANGSMITH_TRACING=<true-only-after-data-handling-and-access-approval>
LANGSMITH_API_KEY=<inject-only-after-ora-008-approval>
PAGERDUTY_ROUTING_KEY_SECRET_ARN=<approved-secrets-manager-arn>
