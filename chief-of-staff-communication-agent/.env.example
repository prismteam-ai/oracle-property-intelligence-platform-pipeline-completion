# AWS (ash + espeon production path)
AWS_REGION=us-east-2

# Bedrock chat + embeddings (Vercel AI SDK @ai-sdk/amazon-bedrock)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_CHAT_MODEL=amazon.nova-lite-v1:0
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
# Brain mode: auto (bedrock when AWS creds set), bedrock, or rules
INDEEDEE_BRAIN_MODE=auto

# LangSmith (build-ai-agents Phase 6)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=indeedee-agent
LANGSMITH_TRACING=true

# Local RAG (build-local-rag-pocs)
INDEEDEE_RAG_DB=data/indeedee-rag.db

# API (local dev)
PORT=8787
API_BASE_URL=http://localhost:8787

# Asana (ash Chat SDK / task tools)
ASANA_PAT=
ASANA_WORKSPACE_GID=

# Gmail OAuth (PR-1 / PR-3 redirect pattern — no OAuth modal)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8787/api/oauth/google/callback
GOOGLE_SSO_REDIRECT_URI=http://localhost:8787/api/auth/google/callback
OAUTH_STATE_SECRET=

# Google SSO login (replaces header role toggle when configured)
INDEEDEE_SSO_ENABLED=true
INDEEDEE_SESSION_SECRET=
INDEEDEE_OWNER_EMAILS=

# Background sync (SLA)
SYNC_INTERVAL_MS=300000
SYNC_OWNER_IDS=demo-owner

# Credential encryption (AC-29) — local AES-256-GCM at rest in libSQL
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
INDEEDEE_SECRETS_BACKEND=local
INDEEDEE_SECRETS_KEY=
INDEEDEE_SECRETS_PREFIX=indeedee

# Production: store OAuth/PAT in AWS Secrets Manager instead of local encryption
# INDEEDEE_SECRETS_BACKEND=secrets-manager
# Twilio SID/token, X API keys, IMAP app passwords, etc. also via Connections UI
