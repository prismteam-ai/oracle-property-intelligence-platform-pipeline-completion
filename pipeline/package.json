{
  "name": "oracle-pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Oracle property-intelligence ingestion pipeline: connectors -> DuckDB -> IPFS -> MCP",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "run": "tsx src/run.ts",
    "load": "tsx src/db/load.ts",
    "build:db": "tsx src/transforms/build.ts",
    "typecheck": "tsc --noEmit",
    "export": "tsx src/publish/export.ts",
    "mcp": "tsx src/mcp/server.ts",
    "publish": "tsx src/publish/publish.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1084.0",
    "@duckdb/node-api": "^1.3.4-alpha.27",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ipfs-only-hash": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
