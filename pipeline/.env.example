# Filebase (IPFS publish) — get these from https://console.filebase.io
# Create an IPFS bucket + an access key pair.
S3_ENDPOINT=https://s3.filebase.io
S3_BUCKET=your-oracle-bucket
S3_ACCESS_KEY_ID=your-filebase-access-key
S3_SECRET_ACCESS_KEY=your-filebase-secret-key

# Optional: higher-throughput Socrata pulls
# SOCRATA_APP_TOKEN=

# After `npm run publish`, this is emitted for the MCP server / UI:
# PROPERTY_QUERY_TABLE_MAP={"santa-clara":"https://ipfs.filebase.io/ipfs/<cid>"}
